# Mercado Pago — https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=

# Secret usado para validar a assinatura (x-signature) dos webhooks.
# Gere/veja em: Painel Mercado Pago → Webhooks → "Segredo para validação"
MERCADOPAGO_WEBHOOK_SECRET=

# URL pública da aplicação (usada como fallback para back_urls).
NEXT_PUBLIC_APP_URL=http://localhost:3000
