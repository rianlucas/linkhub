# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Remetente dos emails transacionais.
# Formatos aceitos:
#   "WellPage <contato@seudominio.com>" (recomendado, domínio verificado na Resend)
#   "onboarding@resend.dev"             (domínio de teste da Resend; só envia para o dono da conta)
EMAIL_FROM="WellPage <onboarding@resend.dev>"

# PostHog — https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
# Use https://us.i.posthog.com (US) ou https://eu.i.posthog.com (EU)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# URL pública da aplicação (ex.: https://bionutri.com.br).
NEXT_PUBLIC_APP_URL=http://localhost:3000

