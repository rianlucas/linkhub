# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Remetente dos emails transacionais.
# Formatos aceitos:
#   "BioNutri <contato@seudominio.com>" (recomendado, domínio verificado na Resend)
#   "onboarding@resend.dev"             (domínio de teste da Resend; só envia para o dono da conta)
EMAIL_FROM="BioNutri <onboarding@resend.dev>"

# URL pública da aplicação (ex.: https://bionutri.com.br).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Diretório para persistência local dos JSONs (founders/waitlist).
# Em produção serverless, se não definir, usa /tmp/linkhub-data.
DATA_DIR=
