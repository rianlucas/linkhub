# Mercado Pago — pegue em https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# URL pública da aplicação (usada para back_urls, webhook, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL pública do webhook (obrigatoriamente HTTPS e acessível pela internet).
# Em localhost, deixe VAZIO — o backend ignora automaticamente.
# Em produção/homolog, use algo como https://app.bionutri.com.br/api/mercadopago/webhook
# (ou um tunel como ngrok em dev: https://abc123.ngrok.app/api/mercadopago/webhook)
MERCADOPAGO_WEBHOOK_URL=
